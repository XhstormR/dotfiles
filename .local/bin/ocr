#!/usr/bin/swift

import PDFKit
import Vision

// 识别语言
let recognitionLanguages = ["zh-Hans", "en-US"]
// 扫描页渲染倍率
let renderScale: CGFloat = 3.0

// 打印错误信息并退出
func fail(_ message: String) -> Never {
    FileHandle.standardError.write(Data((message + "\n").utf8))
    exit(1)
}

// 唯一识别核心：对任意图像源构造的请求处理器执行 Vision 文本识别，返回按行拼接的纯文本
func recognizeText(_ requestHandler: VNImageRequestHandler) -> String {
    // 配置文字识别请求：指定中英文语言并开启语言纠正
    let request = VNRecognizeTextRequest()
    request.recognitionLanguages = recognitionLanguages
    request.usesLanguageCorrection = true

    // 同步执行，失败即报错退出
    do {
        try requestHandler.perform([request])
    } catch {
        fail("识别失败: \(error.localizedDescription)")
    }

    // 收集每个文本观测结果的最优候选；空候选自动跳过
    return (request.results ?? [])
        .compactMap { $0.topCandidates(1).first?.string }
        .joined(separator: "\n")
}

// 单页文本提取策略：优先取原生文字层，缺失时回退到栅格化 Vision OCR
func textForPage(_ page: PDFPage) -> String {
    // 文本型 PDF 直接读取文字层，精度 100% 且无需栅格化
    if let layerText = page.string?.trimmingCharacters(in: .whitespacesAndNewlines),
        !layerText.isEmpty
    {
        return layerText
    }
    // 扫描型/图片型 PDF 无文字层，按可见裁剪框（cropBox）放大栅格化后走图片识别路径
    let box = PDFDisplayBox.cropBox
    let bounds = page.bounds(for: box)
    let size = NSSize(width: bounds.width * renderScale, height: bounds.height * renderScale)
    guard
        let image = page.thumbnail(of: size, for: box)
            .cgImage(forProposedRect: nil, context: nil, hints: nil)
    else {
        fail("PDF 页栅格化失败")
    }
    return recognizeText(VNImageRequestHandler(cgImage: image, options: [:]))
}

// PDF：加载并逐页提取文本，页间以空行分隔
func ocrPDF(_ url: URL) -> String {
    guard let document = PDFDocument(url: url) else {
        fail("无法解析: \(url.path)")
    }
    return (0..<document.pageCount)
        .compactMap { document.page(at: $0).map(textForPage) }
        .joined(separator: "\n\n")
}

// 调用 `file --mime-type` 探测文件真实 MIME 类型，杜绝扩展名伪装
func mimeType(of url: URL) -> String {
    let process = Process()
    let pipe = Pipe()
    process.executableURL = URL(fileURLWithPath: "/usr/bin/file")
    process.arguments = ["--mime-type", "--brief", url.path]
    process.standardOutput = pipe
    do {
        try process.run()
    } catch {
        fail("类型探测失败: \(error.localizedDescription)")
    }
    process.waitUntilExit()

    return String(decoding: pipe.fileHandleForReading.readDataToEndOfFile(), as: UTF8.self)
        .trimmingCharacters(in: .whitespacesAndNewlines)
}

// 按真实 MIME 分派：PDF 走文字层/栅格化路径，任意图片交给 Vision（底层 ImageIO 解码，
// 天然支持 PNG/JPEG/HEIC/TIFF 等），其余类型一律拒绝
func ocr(_ url: URL) -> String {
    let mime = mimeType(of: url)
    switch mime {
    case "application/pdf":
        return ocrPDF(url)
    case let type where type.hasPrefix("image/"):
        return recognizeText(VNImageRequestHandler(url: url, options: [:]))
    default:
        fail("不支持的类型: \(mime)（仅接受 PDF 和图片）")
    }
}

// 入口：校验文件存在后按真实类型分派
guard let file = CommandLine.arguments.dropFirst().first else {
    fail("用法：ocr <图片或 PDF>")
}
let url = URL(fileURLWithPath: (file as NSString).expandingTildeInPath)
guard FileManager.default.fileExists(atPath: url.path) else {
    fail("文件不存在: \(url.path)")
}
print(ocr(url))
