        "ANTHROPIC_AUTH_TOKEN": "sk-innP6c3duu05DtIVmglJyw",
        "ANTHROPIC_CUSTOM_MODEL_OPTION": "anthropic/claude-opus-4.7",
        "ANTHROPIC_MODEL": "anthropic/claude-opus-4.7",
