        "deny": [
            "WebFetch",
            "Read(**/.env)",
            "Bash(rm *)",
            "Bash(sudo *)",
            "Bash(chmod *)",
            "Bash(chown *)",
            "Bash(git push *)"
        ]
    },
    "sandbox": {
        "enabled": true
    },
    "enableAllProjectMcpServers": true,
    "enabledPlugins": {
        "feature-dev@claude-code-plugins": true,
        "frontend-design@claude-code-plugins": true,
        "superpowers@superpowers-marketplace": true
    },
    "alwaysThinkingEnabled": true,
