{
    "servers": {
        "microsoft/playwright-mcp": {
            "type": "stdio",
            "command": "bun",
            "args": ["x", "@playwright/mcp@latest"],
            "gallery": "https://api.mcp.github.com",
            "version": "0.0.1-seed"
        },
        "io.github.ChromeDevTools/chrome-devtools-mcp": {
            "type": "stdio",
            "command": "bun",
            "args": ["x", "chrome-devtools-mcp@latest"],
            "gallery": "https://api.mcp.github.com",
            "version": "0.11.0"
        },
        "io.github.upstash/context7": {
            "type": "stdio",
            "command": "bun",
            "args": ["x", "@upstash/context7-mcp@latest"],
            "gallery": "https://api.mcp.github.com",
            "version": "1.0.0"
        },
        "io.github.github/github-mcp-server": {
            "type": "http",
            "url": "https://api.githubcopilot.com/mcp/",
            "gallery": "https://api.mcp.github.com",
            "version": "0.21.0"
        },
        "sequential-thinking": {
            "type": "stdio",
            "command": "bun",
            "args": ["x", "@modelcontextprotocol/server-sequential-thinking"]
        },
        "daisyui-doc": {
            "type": "http",
            "url": "https://gitmcp.io/saadeghi/daisyui"
        },
        "angular-cli": {
            "type": "stdio",
            "command": "bun",
            "args": ["x", "@angular/cli@latest", "mcp"]
        }
    },
    "inputs": []
}
